# 复制为 .env 并填写。Phase 1 的采集(GDELT/RSS)无需任何 key。
# 智能层(批量富化 / 综合分析)需要 LLM API key。

# Pixel API / OpenAI-compatible API key (与 Claude Code 订阅是分开的)
ANTHROPIC_API_KEY=

# Pixel API 当前是 OpenAI-compatible 网关。
ANTHROPIC_BASE_URL=https://ai-pixel.online
LLM_PROVIDER=openai

# 数据库文件路径 (默认 backend/dossier.db)
# DB_PATH=

# 模型 (混合: 轻量模型批量富化, 强模型做综合)
HAIKU_MODEL=gpt-5.4-mini
SYNTH_MODEL=gpt-5.4

# RSS/gnews 经本机 VPN 代理 (Google News 国内直连不通)。
# v2rayN SOCKS5: socks5://127.0.0.1:10808 | Clash HTTP: http://127.0.0.1:7890
# 留空则直连 (连不上会在 RSS_FETCH_TIMEOUT 秒内快速失败, 不卡死)。
RSS_PROXY=
# RSS_FETCH_TIMEOUT=12
# RSS_FETCH_RETRIES=1

# Reddit 官方 API (无浏览器路线)。配齐则 Reddit 走 API, 否则回退 OpenCLI(需 Chrome+登录)。
# 在 https://www.reddit.com/prefs/apps 注册 "script" 应用拿 client_id/secret。
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=dossier-tool/0.1 (personal research)
